# SECURITY & CLEANUP (Gilt auch innerhalb der erlaubten Ordner)
# ---------------------------------------------------------------

# OS & IDE
.DS_Store
.idea/
.vscode/
*.swp

# Terraform Security
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
*.tfplan
crash.log
.env
.env.local
node_modules/