APP_ENV=production
NODE_ENV=production

BACKEND_PORT=5000
BIND_PUBLIC=true
REQUIRE_AUTH=true
FORCE_HTTPS=true
EXPOSE_INTERNAL_ERRORS=false

JWT_SECRET=change_me
JWT_EXPIRES_HOURS=24
JWT_EXPIRES_HOURS_MAX=24
SESSION_COOKIE_NAME=session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax

# RDS endpoint (from SSM /patientsync/prod/data/rds/endpoint)
DB_HOST=your-rds-endpoint.eu-central-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=patientsync
DB_USER=patientsync_app
DB_PASSWORD=change_me
DB_SSLMODE=verify-full
DB_SSL_REJECT_UNAUTHORIZED=true
REQUIRE_DB_TLS_IN_PROD=true
ALLOW_INSECURE_DB_SSL=false

DEFAULT_TENANT_ID=dhpatientsync
DEFAULT_TENANTS=dhpatientsync
TENANT_CONFIG_PATH=/app/config/tenants.json
TENANT_STORAGE_BASE_PATH=/data/tenants
MIGRATION_SEED_DEMO_DATA=false
TENANT_PROVISIONING_CREATE_DATABASES=false
TENANT_PROVISIONING_HOST=${DB_HOST}
TENANT_PROVISIONING_PORT=${DB_PORT}
TENANT_PROVISIONING_DATABASE=${DB_NAME}
TENANT_PROVISIONING_USER=${DB_USER}
TENANT_PROVISIONING_PASSWORD=${DB_PASSWORD}
TENANT_PROVISIONING_SSLMODE=${DB_SSLMODE}

CORS_ORIGIN=https://your-cloudfront-domain.cloudfront.net
CORS_ALLOWLIST=https://your-cloudfront-domain.cloudfront.net

AI_SERVICE_URL=http://127.0.0.1:8088
AI_GATEWAY_TOKEN=change_me_ai_token
BILLING_SERVICE_URL=http://127.0.0.1:8090
BILLING_SERVICE_TOKEN=change_me_billing_token
SHARED_INTERNAL_SECRET=change_me_shared_secret

# S3 patient documents — IAM EC2 instance role handles credentials, no keys needed
DOCUMENTS_BUCKET_NAME=patientsync-prod-documents-eu-central-2
AWS_REGION=eu-central-2

ENABLE_XSD_VALIDATION=true
INVOICE_XSD_PATH=/app/Tardoc/generalInvoiceRequest_500.xsd
AUDIT_RETENTION_DAYS=90
