APP_ENV=production
NODE_ENV=production
LOGIN_PORT=8080
PORT=8080
BIND_PUBLIC=true
TRUST_PROXY_HOPS=1

# RDS endpoint (from SSM /patientsync/prod/data/rds/endpoint)
DB_HOST=your-rds-endpoint.eu-central-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=patientsync
DB_USER=patientsync_app
DB_PASSWORD=change_me
DB_SSLMODE=verify-full
DB_SSL_REJECT_UNAUTHORIZED=true

JWT_SECRET=change_me
JWT_EXPIRES_HOURS=24
JWT_EXPIRES_HOURS_MAX=24

DEFAULT_TENANT_ID=dhpatientsync
REQUIRE_TENANT_REGISTRY=true
DEFAULT_APP_REDIRECT_URL=https://your-cloudfront-domain.cloudfront.net
TENANT_APP_REDIRECT_MAP=dhpatientsync=https://your-cloudfront-domain.cloudfront.net

SESSION_COOKIE_NAME=session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax

CORS_ORIGIN=https://your-cloudfront-domain.cloudfront.net
