{
  "name": "patientensync-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Swiss clinic-ready Node/Express backend (HTTPS hinter Nginx, JWT-Auth, EDI, PDF, Postgres).",
  "main": "server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "start:backend": "node server.js",
    "start:ai-service": "node llm-gateway/server.js",
    "start:billing-service": "node services/billing-service/server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "dev": "NODE_ENV=development nodemon server.js",
    "health": "curl -s http://127.0.0.1:5000/api/health || true",
    "seed:insurances": "node scripts/seed-insurances.js",
    "migrate": "node ../scripts/migrate.js",
    "seed": "node -e \"(async()=>{const {Client}=require('pg');const fs=require('fs');const path=require('path');const url=process.env.DATABASE_URL;if(!url)throw new Error('DATABASE_URL not set');const c=new Client({connectionString:url});await c.connect();try{const dir=path.join('..','scripts','seed');const files=fs.readdirSync(dir).filter(f=>f.endsWith('.sql')).sort();for(const f of files){const sql=fs.readFileSync(path.join(dir,f),'utf8');console.log('Seeding',f);await c.query(sql);}console.log('Seed complete');}finally{await c.end();}})().catch(e=>{console.error(e.message||e);process.exit(1);})\"",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "e2e": "playwright test --config=../e2e/config/playwright.config.ts",
    "e2e:ui": "playwright test --ui --config=../e2e/config/playwright.config.ts",
    "e2e:install": "playwright install --with-deps",
    "dev:db:up": "docker compose up -d db",
    "dev:db:down": "docker compose down",
    "dev:backend": "cross-env PORT=${BACKEND_PORT:-5000} node server.js",
    "dev:frontend": "cross-env PORT=${FRONTEND_DEV_PORT:-3000} react-scripts start",
    "dev:prep": "cross-env DATABASE_URL=${DATABASE_URL} npm run migrate && cross-env DATABASE_URL=${DATABASE_URL} npm run seed",
    "dev:servers": "run-p dev:backend dev:frontend",
    "dev:all": "run-s dev:db:up dev:prep dev:servers",
    "smoke:test": "node -e \"process.env.CH_QA_SCORE_MIN=process.env.CH_QA_SCORE_MIN||'2';require('./scripts/smoke_test');\"",
    "smoke:extra": "node scripts/smoke_extra.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "form-data": "^4.0.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "http-proxy-middleware": "^2.0.6",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.5",
    "puppeteer": "^24.8.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "npm-run-all": "^4.1.5",
    "react-scripts": "^5.0.1",
    "supertest": "^6.3.4"
  },
  "license": "UNLICENSED"
}
