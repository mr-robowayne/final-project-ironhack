# Public frontend build vars (visible in JS bundle)
# Recommended source of truth: AWS SSM Parameter Store (/patientsync/prod/frontend)
# Recommended in production with CloudFront /api/* -> ALB: keep API base empty
REACT_APP_API_BASE=
REACT_APP_API_URL=

# Tenant defaults
REACT_APP_DEFAULT_TENANT=test

# Optional LanguageTool endpoint (if used)
REACT_APP_LT_API_URL=

# Chat notification body preview in OS notifications
# false = privacy-safe default (no message text shown)
REACT_APP_CHAT_NOTIFICATION_PREVIEW=false

# Dev-only (must be empty in prod)
REACT_APP_BACKEND_PORT=
REACT_APP_DEV_TENANT_ID=
REACT_APP_DEV_USER_ID=

# Security: disable frontend source maps in production exports
GENERATE_SOURCEMAP=false
