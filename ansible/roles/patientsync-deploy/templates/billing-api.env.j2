NODE_ENV=production
PORT={{ ports.billing_api }}
BIND_PUBLIC=true

JWT_SECRET={{ vault_jwt_secret }}
JWT_EXPIRES_HOURS=24
JWT_EXPIRES_HOURS_MAX=24
SESSION_COOKIE_NAME={{ session_cookie_name }}
BILLING_SERVICE_TOKEN={{ vault_billing_service_token }}

DB_HOST={{ vault_db_host }}
DB_PORT={{ db_port }}
DB_NAME={{ db_name }}
DB_USER={{ db_user }}
DB_PASSWORD={{ vault_db_password }}
DB_SSLMODE={{ db_sslmode }}
DB_SSL_REJECT_UNAUTHORIZED=true
REQUIRE_DB_TLS_IN_PROD=true
ALLOW_INSECURE_DB_SSL=false

DEFAULT_TENANT_ID={{ default_tenant_id }}
TENANT_CONFIG_PATH=/app/config/tenants.json
