APP_ENV=production
NODE_ENV=production

BACKEND_PORT={{ ports.backend_api }}
BIND_PUBLIC=true
REQUIRE_AUTH=true
FORCE_HTTPS=true
EXPOSE_INTERNAL_ERRORS=false

JWT_SECRET={{ vault_jwt_secret }}
JWT_EXPIRES_HOURS=24
JWT_EXPIRES_HOURS_MAX=24
SESSION_COOKIE_NAME={{ session_cookie_name }}
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE={{ session_cookie_secure }}
SESSION_COOKIE_SAMESITE={{ session_cookie_samesite }}

DB_HOST={{ vault_db_host }}
DB_PORT={{ db_port }}
DB_NAME={{ db_name }}
DB_USER={{ db_user }}
DB_PASSWORD={{ vault_db_password }}
DB_SSLMODE=require
DB_SSL_REJECT_UNAUTHORIZED=false
REQUIRE_DB_TLS_IN_PROD=false
ALLOW_INSECURE_DB_SSL=true

DEFAULT_TENANT_ID={{ default_tenant_id }}
DEFAULT_TENANTS={{ default_tenant_id }}
TENANT_CONFIG_PATH=/app/config/tenants.json
TENANT_STORAGE_BASE_PATH=/data/tenants
MIGRATION_SEED_DEMO_DATA=false
TENANT_PROVISIONING_CREATE_DATABASES=false
TENANT_PROVISIONING_HOST={{ vault_db_host }}
TENANT_PROVISIONING_PORT={{ db_port }}
TENANT_PROVISIONING_DATABASE={{ db_name }}
TENANT_PROVISIONING_USER={{ db_user }}
TENANT_PROVISIONING_PASSWORD={{ vault_db_password }}
TENANT_PROVISIONING_SSLMODE=require

CORS_ORIGIN=https://{{ cloudfront_domain }}
CORS_ALLOWLIST=https://{{ cloudfront_domain }}

AI_SERVICE_URL=http://127.0.0.1:{{ ports.ai_service }}
AI_GATEWAY_TOKEN={{ vault_ai_gateway_token }}
BILLING_SERVICE_URL=http://127.0.0.1:{{ ports.billing_api }}
BILLING_SERVICE_TOKEN={{ vault_billing_service_token }}

DOCUMENTS_BUCKET_NAME={{ documents_bucket }}
AWS_REGION={{ aws_region }}

ENABLE_XSD_VALIDATION=true
INVOICE_XSD_PATH=/app/Tardoc/generalInvoiceRequest_500.xsd
AUDIT_RETENTION_DAYS=90
