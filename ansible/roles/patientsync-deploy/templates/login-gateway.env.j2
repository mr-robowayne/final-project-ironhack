APP_ENV=production
NODE_ENV=production
LOGIN_PORT={{ ports.login_gateway }}
PORT={{ ports.login_gateway }}
BIND_PUBLIC=true
TRUST_PROXY_HOPS=1

DB_HOST={{ vault_db_host }}
DB_PORT={{ db_port }}
DB_NAME={{ db_name }}
DB_USER={{ db_user }}
DB_PASSWORD={{ vault_db_password }}
DB_SSLMODE=require
DB_SSL_REJECT_UNAUTHORIZED=false
NODE_TLS_REJECT_UNAUTHORIZED=0

JWT_SECRET={{ vault_jwt_secret }}
JWT_EXPIRES_HOURS=24
JWT_EXPIRES_HOURS_MAX=24

DEFAULT_TENANT_ID={{ default_tenant_id }}
REQUIRE_TENANT_REGISTRY=true
DEFAULT_APP_REDIRECT_URL=https://{{ cloudfront_domain }}
TENANT_APP_REDIRECT_MAP={{ default_tenant_id }}=https://{{ cloudfront_domain }}

SESSION_COOKIE_NAME={{ session_cookie_name }}
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE={{ session_cookie_secure }}
SESSION_COOKIE_SAMESITE={{ session_cookie_samesite }}

CORS_ORIGIN=https://{{ cloudfront_domain }}
