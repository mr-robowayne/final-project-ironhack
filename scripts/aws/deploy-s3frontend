#!/usr/bin/env bash
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
FRONTEND_DIR="${FRONTEND_DIR:-$PROJECT_ROOT/app/dhapp/frontend}"
AWS_REGION="${AWS_REGION:-eu-central-2}"
S3_BUCKET="${S3_BUCKET:-}"
CLOUDFRONT_DISTRIBUTION_ID="${CLOUDFRONT_DISTRIBUTION_ID:-}"
CONFIRM_DPA_CH_EU="${CONFIRM_DPA_CH_EU:-false}"
CONFIRM_CLOUDFRONT_LOGGING="${CONFIRM_CLOUDFRONT_LOGGING:-false}"

if [[ -z "${BUILD_INFO_FILE:-}" ]]; then
  if [[ -f "$FRONTEND_DIR/BUILD_INFO.txt" ]]; then
    BUILD_INFO_FILE="$FRONTEND_DIR/BUILD_INFO.txt"
  else
    BUILD_INFO_FILE="$PROJECT_ROOT/app/dhapp/admin/BUILD_INFO_FRONTEND.txt"
  fi
fi

if [[ -z "$S3_BUCKET" || -z "$CLOUDFRONT_DISTRIBUTION_ID" ]]; then
  cat >&2 <<USAGE
Usage:
  AWS_REGION=eu-central-2 \\
  S3_BUCKET=<frontend-bucket> \\
  CLOUDFRONT_DISTRIBUTION_ID=<dist-id> \\
  CONFIRM_DPA_CH_EU=true \\
  bash scripts/deploy-s3frontend
USAGE
  exit 1
fi

for cmd in aws; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "[NO-GO] Missing required command: $cmd" >&2
    exit 1
  fi
done

if command -v rg >/dev/null 2>&1; then
  HAS_RG=true
else
  HAS_RG=false
fi

search_file() {
  local pattern="$1"
  local file="$2"
  if [[ "$HAS_RG" == "true" ]]; then
    rg -n -i "$pattern" "$file" || true
  else
    grep -nEi "$pattern" "$file" || true
  fi
}

search_dir() {
  local pattern="$1"
  local dir="$2"
  if [[ "$HAS_RG" == "true" ]]; then
    rg -n -i "$pattern" "$dir" || true
  else
    grep -RInEi "$pattern" "$dir" || true
  fi
}

search_dir_files() {
  local pattern="$1"
  local dir="$2"
  if [[ "$HAS_RG" == "true" ]]; then
    rg -l -i "$pattern" "$dir" || true
  else
    grep -RIlEi "$pattern" "$dir" || true
  fi
}

FAIL_COUNT=0
WARN_COUNT=0

pass() { echo "[OK]   $*"; }
warn() { echo "[WARN] $*"; WARN_COUNT=$((WARN_COUNT + 1)); }
fail() { echo "[FAIL] $*"; FAIL_COUNT=$((FAIL_COUNT + 1)); }

echo "== Go/No-Go preflight =="
echo "Frontend dir: $FRONTEND_DIR"
echo "Build info : $BUILD_INFO_FILE"
echo "Bucket     : $S3_BUCKET"
echo "CloudFront : $CLOUDFRONT_DISTRIBUTION_ID"
echo

# 1) Build folder minimum content
[[ -f "$FRONTEND_DIR/index.html" ]] && pass "index.html present" || fail "index.html missing"
[[ -f "$FRONTEND_DIR/asset-manifest.json" ]] && pass "asset-manifest.json present" || fail "asset-manifest.json missing"
[[ -d "$FRONTEND_DIR/static" ]] && pass "static/ present" || fail "static/ missing"

# 2) BUILD_INFO checks: REACT_APP_DEV_* empty and no secret-like content
if [[ ! -f "$BUILD_INFO_FILE" ]]; then
  fail "BUILD_INFO file missing: $BUILD_INFO_FILE"
else
  dev_non_empty="$(search_file '^REACT_APP_DEV_[A-Z0-9_]+=.+$' "$BUILD_INFO_FILE")"
  if [[ -n "$dev_non_empty" ]]; then
    fail "REACT_APP_DEV_* must be empty in BUILD_INFO: $(echo "$dev_non_empty" | tr '\n' ' ')"
  else
    pass "REACT_APP_DEV_* values are empty in BUILD_INFO"
  fi

  build_info_secret_hits="$(search_file 'AKIA|SECRET|TOKEN|PASSWORD|PRIVATE KEY|OPENAI|JWT' "$BUILD_INFO_FILE")"
  if [[ -n "$build_info_secret_hits" ]]; then
    fail "Secret-like content found in BUILD_INFO"
  else
    pass "No secret-like content in BUILD_INFO"
  fi
fi

# 3) Secret scan on frontend build
# Keep checklist pattern, but ignore known React production marker:
# "__SECRET_INTERNALS_DO_NOT_USE_OR_YOU_WILL_BE_FIRED"
bundle_secret_hit_files="$(search_dir_files 'AKIA|SECRET|TOKEN|PASSWORD|PRIVATE KEY|OPENAI|JWT' "$FRONTEND_DIR" | sort -u || true)"
if [[ -n "$bundle_secret_hit_files" ]]; then
  filtered_files=""
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    if grep -q "__SECRET_INTERNALS_DO_NOT_USE_OR_YOU_WILL_BE_FIRED" "$f" 2>/dev/null; then
      continue
    fi
    filtered_files+="$f"$'\n'
  done <<< "$bundle_secret_hit_files"

  if [[ -n "$filtered_files" ]]; then
    fail "Secret-scan hit in frontend bundle (file-level)"
    echo "$filtered_files" | sed '/^$/d'
  else
    pass "Secret-scan clean (React __SECRET_INTERNALS false-positive ignored)"
  fi
else
  pass "Secret-scan clean in frontend bundle"
fi

# 4) S3 private posture and encryption
account_id="$(aws sts get-caller-identity --query Account --output text)"

account_bpa="$(aws s3control get-public-access-block \
  --account-id "$account_id" \
  --region "$AWS_REGION" \
  --query 'PublicAccessBlockConfiguration.[BlockPublicAcls,IgnorePublicAcls,BlockPublicPolicy,RestrictPublicBuckets]' \
  --output text 2>/dev/null || true)"
[[ "$account_bpa" == "True	True	True	True" || "$account_bpa" == "True True True True" ]] \
  && pass "Account-level S3 Block Public Access enabled" \
  || fail "Account-level S3 Block Public Access not fully enabled"

bucket_bpa="$(aws s3api get-public-access-block \
  --bucket "$S3_BUCKET" \
  --query 'PublicAccessBlockConfiguration.[BlockPublicAcls,IgnorePublicAcls,BlockPublicPolicy,RestrictPublicBuckets]' \
  --output text 2>/dev/null || true)"
[[ "$bucket_bpa" == "True	True	True	True" || "$bucket_bpa" == "True True True True" ]] \
  && pass "Bucket-level S3 Block Public Access enabled" \
  || fail "Bucket-level S3 Block Public Access not fully enabled"

is_public="$(aws s3api get-bucket-policy-status --bucket "$S3_BUCKET" --query 'PolicyStatus.IsPublic' --output text 2>/dev/null || true)"
[[ "$is_public" == "False" ]] && pass "Bucket policy is not public" || fail "Bucket policy appears public"

if aws s3api get-bucket-website --bucket "$S3_BUCKET" >/dev/null 2>&1; then
  fail "S3 website hosting enabled (must be disabled for OAC-only setup)"
else
  pass "S3 website hosting disabled"
fi

bucket_policy="$(aws s3api get-bucket-policy --bucket "$S3_BUCKET" --query 'Policy' --output text 2>/dev/null || true)"
if [[ -z "$bucket_policy" ]]; then
  fail "Bucket policy missing (expected CloudFront OAC-only access policy)"
elif echo "$bucket_policy" | grep -q 'cloudfront.amazonaws.com'; then
  pass "Bucket policy references CloudFront service principal (OAC style)"
else
  fail "Bucket policy does not reference CloudFront service principal"
fi

enc_alg="$(aws s3api get-bucket-encryption \
  --bucket "$S3_BUCKET" \
  --query 'ServerSideEncryptionConfiguration.Rules[0].ApplyServerSideEncryptionByDefault.SSEAlgorithm' \
  --output text 2>/dev/null || true)"
if [[ "$enc_alg" == "aws:kms" ]]; then
  pass "S3 encryption enabled with SSE-KMS"
elif [[ "$enc_alg" == "AES256" ]]; then
  warn "S3 encryption is SSE-S3 (acceptable), SSE-KMS preferred"
else
  fail "S3 default encryption not configured"
fi

# 5) CloudFront checks: HTTPS, headers policy, SPA fallback, logging
default_vpp="$(aws cloudfront get-distribution-config --id "$CLOUDFRONT_DISTRIBUTION_ID" \
  --query 'DistributionConfig.DefaultCacheBehavior.ViewerProtocolPolicy' --output text)"
if [[ "$default_vpp" == "redirect-to-https" || "$default_vpp" == "https-only" ]]; then
  pass "CloudFront default behavior enforces HTTPS"
else
  fail "CloudFront default behavior does not enforce HTTPS"
fi

non_https_paths="$(aws cloudfront get-distribution-config --id "$CLOUDFRONT_DISTRIBUTION_ID" \
  --query 'DistributionConfig.CacheBehaviors.Items[?ViewerProtocolPolicy!=`redirect-to-https` && ViewerProtocolPolicy!=`https-only`].PathPattern' \
  --output text)"
if [[ -z "$non_https_paths" || "$non_https_paths" == "None" ]]; then
  pass "All ordered behaviors enforce HTTPS"
else
  fail "Some ordered behaviors do not enforce HTTPS: $non_https_paths"
fi

default_rhp="$(aws cloudfront get-distribution-config --id "$CLOUDFRONT_DISTRIBUTION_ID" \
  --query 'DistributionConfig.DefaultCacheBehavior.ResponseHeadersPolicyId' --output text)"
if [[ -n "$default_rhp" && "$default_rhp" != "None" ]]; then
  pass "CloudFront Response Headers Policy configured"
else
  fail "CloudFront Response Headers Policy missing (HSTS/X-Content-Type/Referrer-Policy expected)"
fi

spa_403="$(aws cloudfront get-distribution-config --id "$CLOUDFRONT_DISTRIBUTION_ID" \
  --query 'DistributionConfig.CustomErrorResponses.Items[?ErrorCode==`403`].ResponsePagePath' --output text)"
spa_404="$(aws cloudfront get-distribution-config --id "$CLOUDFRONT_DISTRIBUTION_ID" \
  --query 'DistributionConfig.CustomErrorResponses.Items[?ErrorCode==`404`].ResponsePagePath' --output text)"
if [[ "$spa_403" == *"/index.html"* && "$spa_404" == *"/index.html"* ]]; then
  pass "SPA fallback set (403/404 -> /index.html)"
else
  fail "SPA fallback missing (need 403/404 -> /index.html)"
fi

default_cache_policy="$(aws cloudfront get-distribution-config --id "$CLOUDFRONT_DISTRIBUTION_ID" \
  --query 'DistributionConfig.DefaultCacheBehavior.CachePolicyId' --output text)"
static_cache_policy="$(aws cloudfront get-distribution-config --id "$CLOUDFRONT_DISTRIBUTION_ID" \
  --query 'DistributionConfig.CacheBehaviors.Items[?PathPattern==`/static/*`].CachePolicyId' --output text)"
if [[ -z "$static_cache_policy" || "$static_cache_policy" == "None" ]]; then
  warn "No dedicated /static/* behavior found (upload metadata still enforces long cache on static files)"
elif [[ "$default_cache_policy" == "$static_cache_policy" ]]; then
  warn "Default and /static/* use same cache policy"
else
  pass "Dedicated cache policy detected for /static/*"
fi

legacy_logging_enabled="$(aws cloudfront get-distribution-config --id "$CLOUDFRONT_DISTRIBUTION_ID" \
  --query 'DistributionConfig.Logging.Enabled' --output text)"
legacy_logging_cookies="$(aws cloudfront get-distribution-config --id "$CLOUDFRONT_DISTRIBUTION_ID" \
  --query 'DistributionConfig.Logging.IncludeCookies' --output text)"
legacy_logging_bucket="$(aws cloudfront get-distribution-config --id "$CLOUDFRONT_DISTRIBUTION_ID" \
  --query 'DistributionConfig.Logging.Bucket' --output text)"

log_bucket=""

if [[ "$legacy_logging_enabled" == "True" ]]; then
  pass "CloudFront logging enabled (legacy distribution logging)"
  [[ "$legacy_logging_cookies" == "False" ]] && pass "CloudFront logs exclude cookies (data minimization)" || warn "CloudFront logs include cookies"
  if [[ -n "$legacy_logging_bucket" && "$legacy_logging_bucket" != "None" ]]; then
    log_bucket="${legacy_logging_bucket%%.s3.amazonaws.com}"
  fi
else
  # Terraform in this repo uses CloudFront Standard Logging v2 (CloudWatch log delivery).
  distribution_arn="$(aws cloudfront get-distribution --id "$CLOUDFRONT_DISTRIBUTION_ID" --query 'Distribution.ARN' --output text 2>/dev/null || true)"
  v2_source_names=""
  v2_delivery_destination_arn=""
  v2_delivery_found=false
  v2_check_inconclusive=false

  if [[ -n "$distribution_arn" && "$distribution_arn" != "None" ]]; then
    v2_source_names="$(aws logs describe-delivery-sources --region us-east-1 \
      --query "deliverySources[?resourceArn=='${distribution_arn}'].name" \
      --output text 2>/dev/null || true)"
    if [[ -z "$v2_source_names" || "$v2_source_names" == "None" ]]; then
      # Could be truly absent, or API permission/endpoint issue.
      if ! aws logs describe-delivery-sources --region us-east-1 --max-items 1 >/dev/null 2>&1; then
        v2_check_inconclusive=true
      fi
    fi
  fi

  if [[ -n "$v2_source_names" && "$v2_source_names" != "None" ]]; then
    for src in $v2_source_names; do
      delivery_count="$(aws logs describe-deliveries --region us-east-1 \
        --query "length(deliveries[?deliverySourceName=='${src}'])" \
        --output text 2>/dev/null || true)"
      if [[ "$delivery_count" =~ ^[0-9]+$ ]] && (( delivery_count > 0 )); then
        v2_delivery_found=true
        v2_delivery_destination_arn="$(aws logs describe-deliveries --region us-east-1 \
          --query "deliveries[?deliverySourceName=='${src}']|[0].deliveryDestinationArn" \
          --output text 2>/dev/null || true)"
        break
      fi
    done
  fi

  if [[ "$v2_delivery_found" == "true" ]]; then
    pass "CloudFront logging enabled (standard logging v2)"
    pass "CloudFront logs exclude cookies (data minimization; v2)"

    if [[ -n "$v2_delivery_destination_arn" && "$v2_delivery_destination_arn" != "None" ]]; then
      destination_resource_arn="$(aws logs describe-delivery-destinations --region us-east-1 \
        --query "deliveryDestinations[?arn=='${v2_delivery_destination_arn}']|[0].deliveryDestinationConfiguration.destinationResourceArn" \
        --output text 2>/dev/null || true)"
      if [[ "$destination_resource_arn" == arn:aws:s3:::* ]]; then
        log_bucket="${destination_resource_arn#arn:aws:s3:::}"
      fi
    fi
  else
    if [[ "$CONFIRM_CLOUDFRONT_LOGGING" == "true" ]]; then
      pass "CloudFront logging manually confirmed"
      warn "CloudFront logging auto-detection did not find delivery; manual confirmation override used"
    elif [[ "$v2_check_inconclusive" == "true" ]]; then
      fail "CloudFront logging verification inconclusive via API. Set CONFIRM_CLOUDFRONT_LOGGING=true only if verified in console."
    else
      fail "CloudFront logging disabled (neither legacy logging nor logging v2 delivery detected)"
    fi
  fi
fi

if [[ -n "$log_bucket" && "$log_bucket" != "None" ]]; then
  if aws s3api get-bucket-lifecycle-configuration --bucket "$log_bucket" >/dev/null 2>&1; then
    pass "Log bucket lifecycle/retention configured"
  else
    warn "Log bucket lifecycle/retention not found"
  fi
else
  warn "CloudFront log bucket not detected"
fi

# 6) Manual compliance checkpoint
if [[ "$CONFIRM_DPA_CH_EU" == "true" ]]; then
  pass "Manual DPA/AVV + CH/EU transfer assessment confirmed"
else
  fail "Manual check missing: set CONFIRM_DPA_CH_EU=true only if DPA/AVV and CH/EU transfer assessment are documented"
fi

echo
echo "Summary: ${FAIL_COUNT} FAIL, ${WARN_COUNT} WARN"
if (( FAIL_COUNT > 0 )); then
  echo "NO-GO: upload aborted."
  exit 1
fi

echo "GO: all blocking checks passed. Starting upload..."

# Upload with cache strategy:
# - static/*: long immutable cache
# - index/manifest/root assets: no cache
if [[ -d "$FRONTEND_DIR/static" ]]; then
  aws s3 sync "$FRONTEND_DIR/static" "s3://$S3_BUCKET/static" \
    --delete \
    --exclude "*.map" \
    --cache-control "public,max-age=31536000,immutable"
fi

aws s3 sync "$FRONTEND_DIR" "s3://$S3_BUCKET" \
  --delete \
  --exclude "static/*" \
  --exclude "*.map" \
  --exclude "BUILD_INFO.txt" \
  --cache-control "no-cache,no-store,must-revalidate"

for f in index.html manifest.json; do
  if [[ -f "$FRONTEND_DIR/$f" ]]; then
    aws s3 cp "$FRONTEND_DIR/$f" "s3://$S3_BUCKET/$f" \
      --cache-control "no-cache,no-store,must-revalidate"
  fi
done

aws s3 rm "s3://$S3_BUCKET/static" --recursive --exclude "*" --include "*.map" >/dev/null || true
aws s3 rm "s3://$S3_BUCKET/BUILD_INFO.txt" >/dev/null || true

aws cloudfront create-invalidation \
  --distribution-id "$CLOUDFRONT_DISTRIBUTION_ID" \
  --paths "/*" >/dev/null

echo "[DONE] Frontend uploaded and CloudFront invalidated."
